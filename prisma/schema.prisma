generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  organization      String?
  website           String?
  avatarUrl         String?
  phone             String?   @unique
  email             String    @unique
  passwordHash      String
  role              String    @default("user")
  createdAt         DateTime  @default(now())
  passwordChangedAt DateTime  @default(now())

  ads              Ad[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  resetTokens      PasswordResetToken[]
  notifications    Notification[]
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Ad {
  id          Int       @id @default(autoincrement())
  userId      Int
  title       String
  category    String
  description String
  price       Float?
  city        String
  address     String?
  status          String    @default("pending")
  rejectionReason String?
  slug            String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  images      AdImage[]
}

model AdImage {
  id        Int    @id @default(autoincrement())
  adId      Int
  imageUrl  String
  sortOrder Int    @default(0)

  ad        Ad     @relation(fields: [adId], references: [id], onDelete: Cascade)
}

model Setting {
  key   String @id
  value String
}

model Category {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  nameRu     String
  nameEn     String
  iconBg     String   @default("#E0F7F6")
  iconColor  String   @default("#02282C")
  iconSvg    String   @default("")
  imageUrl   String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subcategories Subcategory[]
}

model Subcategory {
  id         Int      @id @default(autoincrement())
  categoryId Int
  slug       String
  nameRu     String
  nameEn     String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@index([categoryId])
}

model Message {
  id         Int      @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  text       String   @default("")
  imageUrl   String?
  isRead     Boolean  @default(false)
  emailSent  Boolean  @default(false)
  createdAt  DateTime @default(now())

  fromUser   User     @relation("SentMessages", fields: [fromUserId], references: [id])
  toUser     User     @relation("ReceivedMessages", fields: [toUserId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // 'ad_approved' | 'ad_rejected' | 'ad_inactive' | 'ad_active'
  adId      Int
  adTitle    String
  adSlug     String
  adImageUrl String?
  reason     String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
